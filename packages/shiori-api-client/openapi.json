  },
  "paths": {
    "/api/v1/libraries": {
      "get": {
        "tags": [
          "library"
        ],
        "summary": "List all libraries.",
        "operationId": "list_libraries",
        "responses": {
          "200": {
            "description": "Successfully fetched libraries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "id",
                      "name",
                      "path",
                      "created_at"
                    ],
                    "properties": {
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Timestamp of when the media was created.",
                        "example": "2024-11-08T17:23:41Z"
                      },
                      "id": {
                        "type": "integer",
                        "format": "int32",
                        "description": "Unique identifier for the library.",
                        "example": 86
                      },
                      "name": {
                        "type": "string",
                        "description": "Name of the library.",
                        "example": "Light Novels"
                      },
                      "path": {
                        "type": "string",
                        "description": "File system path to the library's directory.",
                        "example": "/data/books/light_novels"
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "post": {
        "tags": [
          "library"
        ],
        "summary": "Create a new library.",
        "operationId": "create_library",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "path"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Name of the library."
                  },
                  "path": {
                    "type": "string",
                    "description": "File system path to the library's directory."
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successfully created library",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "id",
                    "name",
                    "path",
                    "created_at"
                  ],
                  "properties": {
                    "created_at": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Timestamp of when the media was created.",
                      "example": "2024-11-08T17:23:41Z"
                    },
                    "id": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Unique identifier for the library.",
                      "example": 86
                    },
                    "name": {
                      "type": "string",
                      "description": "Name of the library.",
                      "example": "Light Novels"
                    },
                    "path": {
                      "type": "string",
                      "description": "File system path to the library's directory.",
                      "example": "/data/books/light_novels"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/v1/libraries/{id}": {
      "get": {
        "tags": [
          "library"
        ],
        "summary": "Fetch library.",
        "description": "Not implemented",
        "operationId": "get_library",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Id of the library",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully fetched library"
          },
          "404": {
            "description": "Library not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/v1/libraries/{id}/media": {
      "get": {
        "tags": [
          "library"
        ],
        "summary": "List library media.",
        "operationId": "list_library_media",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Id of the library",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully fetched library media",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "id",
                      "name",
                      "size",
                      "path",
                      "extension",
                      "created_at",
                      "library_id"
                    ],
                    "properties": {
                      "cover_path": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Endpoint where the cover is stored.",
                        "example": "/api/v1/media/4/cover"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Timestamp of when the media was created.",
                        "example": "2026-03-23T12:00:00Z"
                      },
                      "extension": {
                        "type": "string",
                        "description": "File extension of the media.",
                        "example": "epub"
                      },
                      "id": {
                        "type": "integer",
                        "format": "int32",
                        "description": "Unique identifier for the media item.",
                        "example": 86
                      },
                      "library_id": {
                        "type": "integer",
                        "format": "int32",
                        "description": "Library this media belongs to.",
                        "example": 2
                      },
                      "name": {
                        "type": "string",
                        "description": "Name of the media file, excluding extension.",
                        "example": "86_Volume_1"
                      },
                      "path": {
                        "type": "string",
                        "description": "File system path where the media is stored.",
                        "example": "/data/books/light_novels/86_Volume_1.epub"
                      },
                      "size": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Size of the media file in bytes.",
                        "example": "102400"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Library not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "post": {
        "tags": [
          "library"
        ],
        "summary": "Upload a new media item to the specified library.",
        "operationId": "create_library_media",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Id of the library",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "files"
                ],
                "properties": {
                  "files": {
                    "type": "array",
                    "items": {
                      "type": "integer",
                      "format": "binary",
                      "minimum": 0
                    },
                    "description": "An array of files to upload."
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successfully added media to the library",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "id",
                      "name",
                      "size",
                      "path",
                      "extension",
                      "created_at",
                      "library_id"
                    ],
                    "properties": {
                      "cover_path": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Endpoint where the cover is stored.",
                        "example": "/api/v1/media/4/cover"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Timestamp of when the media was created.",
                        "example": "2026-03-23T12:00:00Z"
                      },
                      "extension": {
                        "type": "string",
                        "description": "File extension of the media.",
                        "example": "epub"
                      },
                      "id": {
                        "type": "integer",
                        "format": "int32",
                        "description": "Unique identifier for the media item.",
                        "example": 86
                      },
                      "library_id": {
                        "type": "integer",
                        "format": "int32",
                        "description": "Library this media belongs to.",
                        "example": 2
                      },
                      "name": {
                        "type": "string",
                        "description": "Name of the media file, excluding extension.",
                        "example": "86_Volume_1"
                      },
                      "path": {
                        "type": "string",
                        "description": "File system path where the media is stored.",
                        "example": "/data/books/light_novels/86_Volume_1.epub"
                      },
                      "size": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Size of the media file in bytes.",
                        "example": "102400"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid uploaded media"
          },
          "404": {
            "description": "Library not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/v1/media/{id}": {
      "get": {
        "tags": [
          "media"
        ],
        "summary": "Fetch media item.",
        "operationId": "get_media",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Id of the media item",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully fetched media cover",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/Media"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "metadata": {
                          "oneOf": [
                            {
                              "type": "null"
                            },
                            {
                              "$ref": "#/components/schemas/MediaMetadata"
                            }
                          ]
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Media not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "patch": {
        "tags": [
          "media"
        ],
        "summary": "Update media information.",
        "operationId": "patch_media",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Id of the media item",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cover_url": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "URL of the cover image associated with the media.",
                    "examples": [
                      "https://example.com/cover.jpg"
                    ]
                  },
                  "metadata": {
                    "oneOf": [
                      {
                        "type": "null"
                      },
                      {
                        "$ref": "#/components/schemas/PatchMetadata",
                        "description": "Optional metadata to update for the media item."
                      }
                    ]
                  },
                  "name": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Name of the media item.",
                    "examples": [
                      "86—EIGHTY-SIX, Vol. 1"
                    ]
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successfully updated media information",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/Media"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "metadata": {
                          "oneOf": [
                            {
                              "type": "null"
                            },
                            {
                              "$ref": "#/components/schemas/MediaMetadata"
                            }
                          ]
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Media not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/v1/media/{id}/cover": {
      "get": {
        "tags": [
          "media"
        ],
        "summary": "Fetch media cover.",
        "operationId": "get_media_cover",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Id of the media item",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully fetched media cover"
          },
          "404": {
            "description": "Media or cover not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/v1/metadata/search": {
      "get": {
        "tags": [
          "metadata"
        ],
        "summary": "Search for metadata.",
        "operationId": "search_metadata",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "A search query string.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "provider",
            "in": "query",
            "description": "The provider to use for the search.\nDefaults to \"goodreads\" if not provided in the query.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully found metadata",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "title",
                    "authors",
                    "genres"
                  ],
                  "properties": {
                    "authors": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "List of authors associated with the media item.",
                      "example": [
                        "Asato Asato"
                      ]
                    },
                    "cover_url": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "description": "URL of the cover image associated with the media.",
                      "example": "https://example.com/cover.jpg"
                    },
                    "description": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "description": "Description of the media item.",
                      "example": "The San Magnolia Republic..."
                    },
                    "genres": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "List of genres associated with the media item.",
                      "example": [
                        "Light Novel",
                        "War"
                      ]
                    },
                    "isbn": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "description": "International Standard Book Number (ISBN).\nTypically used for books.",
                      "example": "1975303121"
                    },
                    "language": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "description": "Language of the media content.",
                      "example": "English"
                    },
                    "published_at": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "format": "date",
                      "description": "Date the media was published.",
                      "example": "2019-03-26"
                    },
                    "publisher": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "description": "Name of the publisher or publishing organization.",
                      "example": "Yen On"
                    },
                    "title": {
                      "type": "string",
                      "description": "Title of the media item.",
                      "example": "86—EIGHTY-SIX, Vol. 1"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  },
