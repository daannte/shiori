                    ]
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successfully registered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "id",
                    "username",
                    "is_server_owner",
                    "created_at"
                  ],
                  "properties": {
                    "created_at": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Timestamp of when the user was created.",
                      "examples": [
                        "2025-07-25T12:45:19Z"
                      ]
                    },
                    "id": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Unique identifier for the user.",
                      "examples": [
                        86
                      ]
                    },
                    "is_server_owner": {
                      "type": "boolean",
                      "description": "Indicates whether the user is the owner of the server.",
                      "examples": [
                        false
                      ]
                    },
                    "username": {
                      "type": "string",
                      "description": "Username of the user.",
                      "examples": [
                        "Reaper"
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request payload"
          },
          "409": {
            "description": "Username already taken"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/v1/filesystem/directories/list": {
      "post": {
        "tags": [
          "filesystem"
        ],
        "summary": "List filesystem directories.",
        "description": "The provided path must be **relative** to application's base directory.",
        "operationId": "list_directories",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "path"
                ],
                "properties": {
                  "path": {
                    "type": "string",
                    "description": "Path of the directory to list its subdirectories.",
                    "examples": [
                      ""
                    ]
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successfully listed directories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "parent",
                    "directories"
                  ],
                  "properties": {
                    "directories": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "examples": [
                          "light_novels"
                        ]
                      },
                      "description": "Immediate subdirectories of the given path."
                    },
                    "parent": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "description": "Parent directory of the given path.",
                      "examples": [
                        null
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid path"
          },
          "403": {
            "description": "Access to the request path is not allowed"
          },
          "404": {
            "description": "Directory does not exist"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "cookie": []
          },
          {
            "api_token": []
          }
        ]
      }
    },
    "/api/v1/libraries": {
      "get": {
        "tags": [
          "library"
        ],
        "summary": "List all libraries.",
        "operationId": "list_libraries",
        "responses": {
          "200": {
            "description": "Successfully fetched libraries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "id",
                      "name",
                      "path",
                      "created_at"
                    ],
                    "properties": {
                      "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "description": "Timestamp of when the media was created.",
                        "examples": [
                          "2024-11-08T17:23:41Z"
                        ]
                      },
                      "id": {
                        "type": "integer",
                        "format": "int32",
                        "description": "Unique identifier for the library.",
                        "examples": [
                          86
                        ]
                      },
                      "name": {
                        "type": "string",
                        "description": "Name of the library.",
                        "examples": [
                          "Light Novels"
                        ]
                      },
                      "path": {
                        "type": "string",
                        "description": "File system path to the library's directory.",
                        "examples": [
                          "/data/books/light_novels"
                        ]
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "cookie": []
          },
          {
            "api_token": []
          }
        ]
