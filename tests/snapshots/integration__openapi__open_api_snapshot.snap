{
  "openapi": "3.1.0",
  "info": {
    "title": "Shiori",
    "description": "TODO",
    "license": {
      "name": ""
    },
    "version": "0.0.0"
  },
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Login",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password"
                ],
                "properties": {
                  "password": {
                    "type": "string",
                    "description": "Password associated with the account.",
                    "examples": [
                      "supercoolpass"
                    ]
                  },
                  "username": {
                    "type": "string",
                    "description": "Username of the account.",
                    "examples": [
                      "Reaper"
                    ]
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successfully logged in",
            "headers": {
              "set-cookie": {
                "schema": {
                  "type": "string"
                },
                "description": "Sets access_token and refresh_token cookies"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "id",
                    "username",
                    "is_server_owner",
                    "created_at"
                  ],
                  "properties": {
                    "created_at": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Timestamp of when the user was created.",
                      "examples": [
                        "2025-07-25T12:45:19Z"
                      ]
                    },
                    "id": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Unique identifier for the user.",
                      "examples": [
                        86
                      ]
                    },
                    "is_server_owner": {
                      "type": "boolean",
                      "description": "Indicates whether the user is the owner of the server.",
                      "examples": [
                        false
                      ]
                    },
                    "username": {
                      "type": "string",
                      "description": "Username of the user.",
                      "examples": [
                        "Reaper"
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Logout",
        "operationId": "logout",
        "responses": {
          "204": {
            "description": "Successfully logged out",
            "headers": {
              "set-cookie": {
                "schema": {
                  "type": "string"
                },
                "description": "Removes access_token and refresh_token cookies"
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "cookie": []
          }
        ]
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Currently authenticated user",
        "operationId": "me",
        "responses": {
          "200": {
            "description": "Successfully retrieved current user",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "id",
                    "username",
                    "is_server_owner",
                    "created_at"
                  ],
                  "properties": {
                    "created_at": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Timestamp of when the user was created.",
                      "examples": [
                        "2025-07-25T12:45:19Z"
                      ]
                    },
                    "id": {
                      "type": "integer",
                      "format": "int32",
                      "description": "Unique identifier for the user.",
                      "examples": [
                        86
                      ]
                    },
                    "is_server_owner": {
                      "type": "boolean",
                      "description": "Indicates whether the user is the owner of the server.",
                      "examples": [
                        false
                      ]
                    },
                    "username": {
                      "type": "string",
                      "description": "Username of the user.",
                      "examples": [
                        "Reaper"
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "cookie": []
          },
          {
            "api_token": []
          }
        ]
      }
    },
    "/api/v1/auth/refresh-token": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Refresh JWT token",
        "operationId": "refresh_token",
        "parameters": [
          {
            "name": "refresh_token",
            "in": "cookie",
            "description": "Refresh token",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successfully refreshed JWT token",
            "headers": {
              "set-cookie": {
                "schema": {
                  "type": "string"
                },
                "description": "Sets access_token and refresh_token HttpOnly cookies"
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
